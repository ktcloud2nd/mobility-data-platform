PORT=4000

# Local PostgreSQL example
# Replace YOUR_POSTGRES_PASSWORD with the password you set in pgAdmin/PostgreSQL.
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/web_platform

# Deploy example
# DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@TERRAFORM_CREATED_DB_ENDPOINT:5432/web_platform
# Or use split env values coming from Terraform outputs / Kubernetes secrets:
# DB_HOST=TERRAFORM_CREATED_DB_ENDPOINT
# DB_PORT=5432
# DB_NAME=web_platform
# DB_USER=DB_USER
# DB_PASSWORD=DB_PASSWORD
# DB_SSL_MODE=require
# DB_SSL_REJECT_UNAUTHORIZED=false

AWS_REGION=ap-northeast-2
